<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Client Insight (AI)</masterLabel>
    <description>RAG-powered assistant that answers natural-language questions about an account, grounded in Salesforce data.</description>
    <targets>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <property
                name="cardTitle"
                type="String"
                label="Card title"
                default="Client Insight (AI)"/>
            <property
                name="defaultQuestion"
                type="String"
                label="Default question"
                description="Pre-filled question shown when the component loads."/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
