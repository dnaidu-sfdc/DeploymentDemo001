# This file is used for Git repositories to specify intentionally untracked files that Git should ignore. 
# If you are not using git, you can delete this file. For more information see: https://git-scm.com/docs/gitignore
# For useful gitignore templates see: https://github.com/github/gitignore

# Salesforce cache
.sf/
.sfdx/
.localdevserver/
deploy-options.json

# LWC VSCode autocomplete
**/lwc/jsconfig.json

# LWC Jest coverage reports
coverage/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
node_modules/

# ApexPMD cache
.pmdCache

# Eslint cache
.eslintcache

# MacOS system files
.DS_Store

# Windows system files
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Local environment variables
.env

# Secrets / CI keys (JWT bearer auth) - never commit
*.key
server.key
*.p12
jwt/

# Not part of the deployment-demo repo (kept local only)
docs/
force-app/
manifest/
scripts/
.husky/
.vscode/
.prettierignore
.prettierrc
eslint.config.js
jest.config.js
package.json
package-lock.json

# Python Salesforce Functions
**/__pycache__/
**/.venv/
**/venv/
