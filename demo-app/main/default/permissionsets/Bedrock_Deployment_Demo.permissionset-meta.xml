<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Bedrock Deployment Demo</label>
    <description>Grants access to the Deployment Demo object, its fields, tab, and the DeploymentDemoService Apex class for the DevSecOps CI/CD demo.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <objectPermissions>
        <object>Deployment_Demo__c</object>
        <allowCreate>true</allowCreate>
        <allowRead>true</allowRead>
        <allowEdit>true</allowEdit>
        <allowDelete>true</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <fieldPermissions>
        <field>Deployment_Demo__c.Status__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Deployment_Demo__c.Notes__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Deployment_Demo__c.Amount__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Deployment_Demo__c.Processed__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <classAccesses>
        <apexClass>DeploymentDemoService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <tabSettings>
        <tab>Deployment_Demo__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
</PermissionSet>
