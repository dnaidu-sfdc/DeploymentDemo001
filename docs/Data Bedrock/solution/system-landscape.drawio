        <mxCell id="subtitle" value="Solid = Data Movement (a copy is written into Salesforce) · Dashed = Data Lookup (shown live, never stored)" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="38" width="1000" height="20" as="geometry" />
