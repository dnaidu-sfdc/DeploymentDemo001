<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram id="bedrock-role-hierarchy" name="Role Hierarchy">
    <mxGraphModel dx="1440" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1440" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Bedrock Auto — Role Hierarchy &amp; Licenses" style="text;html=1;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;fontColor=#1A1A66;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="800" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Internal roles roll up for visibility · External (Experience Cloud) partners &amp; consumers share via roles / Sharing Sets" style="text;html=1;fontSize=12;align=left;verticalAlign=middle;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="38" width="1000" height="20" as="geometry" />
        </mxCell>

        <!-- ================= INTERNAL BAND ================= -->
        <mxCell id="band_int" value="INTERNAL — Service Cloud users" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EAF2FB;strokeColor=#8FB4E0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontStyle=1;fontColor=#1F4E86;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="820" height="560" as="geometry" />
        </mxCell>

        <!-- VP -->
        <mxCell id="vp" value="&lt;b&gt;Service VP&lt;/b&gt;&lt;br&gt;Service Cloud + CRM Analytics&lt;br&gt;Cross-region case reporting" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#2E74B5;verticalAlign=middle;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="120" width="240" height="70" as="geometry" />
        </mxCell>

        <!-- Second tier: RSM, Service Ops -->
        <mxCell id="rsm" value="&lt;b&gt;Regional Service Manager&lt;/b&gt; (×50)&lt;br&gt;Service Cloud&lt;br&gt;Region cases + manages Dealers" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#2E74B5;verticalAlign=middle;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="260" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ops" value="&lt;b&gt;Service Operations&lt;/b&gt;&lt;br&gt;Service Cloud + CRM Analytics + Data Cloud&lt;br&gt;Near-real-time ops dashboards" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#2E74B5;verticalAlign=middle;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="260" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Third tier: Agents + Special agents -->
        <mxCell id="agent" value="&lt;b&gt;Service Agents&lt;/b&gt; (10 per region)&lt;br&gt;Service Cloud&lt;br&gt;Cases via phone/email/web/chat/social&lt;br&gt;author Knowledge articles" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#2E74B5;verticalAlign=middle;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="420" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="special" value="&lt;b&gt;Special Agents&lt;/b&gt; (teams of 3 / region)&lt;br&gt;Service Cloud + permission set&lt;br&gt;Dealer-complaint queue (Restriction Rules)&lt;br&gt;&lt;i&gt;fluid: move in/out via perm set, not license&lt;/i&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#2E74B5;dashed=1;verticalAlign=middle;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="540" width="240" height="90" as="geometry" />
        </mxCell>

        <!-- Account Executives (Sales Cloud) -->
        <mxCell id="ae" value="&lt;b&gt;Account Executives&lt;/b&gt;&lt;br&gt;Sales Cloud (+ Data Cloud)&lt;br&gt;360° view of large customers&lt;br&gt;recurring-billing insight" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#2E74B5;verticalAlign=middle;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="420" width="240" height="90" as="geometry" />
        </mxCell>

        <!-- ================= EXTERNAL BAND ================= -->
        <mxCell id="band_ext" value="EXTERNAL — Experience Cloud" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECFBF3;strokeColor=#8FCDAE;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontStyle=1;fontColor=#2E8B57;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="900" y="80" width="500" height="560" as="geometry" />
        </mxCell>

        <!-- Dealer partner roles -->
        <mxCell id="dsm" value="&lt;b&gt;Dealership Service Manager (DSM)&lt;/b&gt;&lt;br&gt;Partner Community (login-based)&lt;br&gt;Delegated External Admin&lt;br&gt;sees all DSC-owned records" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;verticalAlign=middle;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="960" y="140" width="280" height="90" as="geometry" />
        </mxCell>
        <mxCell id="dsc" value="&lt;b&gt;Dealership Service Consultant (DSC)&lt;/b&gt;&lt;br&gt;Partner Community (login-based)&lt;br&gt;cases, invoices, parts orders&lt;br&gt;15K dealers · 75K employees" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;verticalAlign=middle;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="960" y="290" width="280" height="90" as="geometry" />
        </mxCell>

        <!-- Consumers (no role) -->
        <mxCell id="consumer" value="&lt;b&gt;Consumers&lt;/b&gt; (2M)&lt;br&gt;Customer Community — High-Volume (login)&lt;br&gt;&lt;b&gt;NO ROLE&lt;/b&gt; → access via &lt;b&gt;Sharing Sets&lt;/b&gt;&lt;br&gt;own vehicles / cases / orders · read articles" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;dashed=1;verticalAlign=middle;align=center;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="960" y="450" width="280" height="110" as="geometry" />
        </mxCell>

        <!-- ================= HIERARCHY EDGES (internal) ================= -->
        <mxCell id="r1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;strokeColor=#2E74B5;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="vp" target="rsm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;strokeColor=#2E74B5;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="vp" target="ops">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;strokeColor=#2E74B5;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="rsm" target="agent">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;strokeColor=#2E74B5;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="agent" target="special">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;strokeColor=#2E74B5;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="ops" target="ae">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- External hierarchy edges -->
        <mxCell id="r6" value="partner role" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;strokeColor=#82B366;strokeWidth=2;fontSize=9;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="dsm" target="dsc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r7" value="Sharing Sets (no role)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=none;dashed=1;strokeColor=#82B366;fontSize=9;fontColor=#2E8B57;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="dsc" target="consumer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================= NOTES / LEGEND ================= -->
        <mxCell id="note1" value="&lt;b&gt;Regional visibility&lt;/b&gt; = role hierarchy (VP ▸ RSM ▸ Agents) + owner-based sharing rules on a Region field. Case &amp; Account OWD = Private." style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="655" width="800" height="30" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="&lt;b&gt;Dealer-complaint cases&lt;/b&gt; are confidential: record type + region Special-Agent queue + Restriction Rules hide them from everyone else, including managers above." style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="685" width="800" height="30" as="geometry" />
        </mxCell>
        <mxCell id="note3" value="&lt;b&gt;Why no role for 2M consumers?&lt;/b&gt; High-Volume Community users have no role → avoids sharing-recalculation pain &amp; data skew at scale. Each consumer sees only their own records via Sharing Sets." style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#2E8B57;" vertex="1" parent="1">
          <mxGeometry x="900" y="580" width="500" height="50" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
