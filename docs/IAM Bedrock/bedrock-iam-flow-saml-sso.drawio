<mxfile host="app.diagrams.net" type="device" version="24.0.0">
  <diagram id="bedrock-iam-saml-flow" name="SAML SSO + MFA + JIT">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Title + subtitle ===== -->
        <mxCell id="title" value="&lt;b&gt;Employee Authentication &#8212; SP-initiated SAML 2.0 SSO + MFA + Just-in-Time Provisioning&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="30" y="10" width="1100" height="24" as="geometry" /></mxCell>
        <mxCell id="subtitle" value="Covers R1 (One Bedrock SSO) &#183; R2 (JIT) &#183; R3 (intranet-only) &#183; R4/MFA &#183; R12 (one-time ToS). Browser is the relay for every redirect; MyDomain is the SAML Service Provider (ACS)." style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#5B6770;" vertex="1" parent="1"><mxGeometry x="30" y="34" width="1180" height="20" as="geometry" /></mxCell>

        <!-- ===== Lifeline headers ===== -->
        <mxCell id="a1" value="Employee&lt;br/&gt;Browser" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DCE8FB;strokeColor=#3B6FD4;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="70" width="150" height="48" as="geometry" /></mxCell>
        <mxCell id="a2" value="Salesforce&lt;br/&gt;MyDomain (SP / ACS)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8EEFB;strokeColor=#1A1A66;strokeWidth=1.5;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="320" y="70" width="170" height="48" as="geometry" /></mxCell>
        <mxCell id="a3" value="Corporate&lt;br/&gt;Federation Hub (IdP)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DCE8FB;strokeColor=#1F6FBF;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="610" y="70" width="170" height="48" as="geometry" /></mxCell>
        <mxCell id="a4" value="Active&lt;br/&gt;Directory" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F2F4F7;strokeColor=#5B6770;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="900" y="70" width="150" height="48" as="geometry" /></mxCell>
        <mxCell id="a5" value="MFA &#8212; SMS OTP&lt;br/&gt;(2nd factor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F7E9EA;strokeColor=#C0392B;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1110" y="70" width="150" height="48" as="geometry" /></mxCell>

        <!-- ===== Lifelines (dashed verticals) ===== -->
        <mxCell id="ll1" style="endArrow=none;html=1;strokeColor=#3B6FD4;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="118" as="sourcePoint" /><mxPoint x="135" y="840" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll2" style="endArrow=none;html=1;strokeColor=#1A1A66;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="405" y="118" as="sourcePoint" /><mxPoint x="405" y="840" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll3" style="endArrow=none;html=1;strokeColor=#1F6FBF;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="695" y="118" as="sourcePoint" /><mxPoint x="695" y="840" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll4" style="endArrow=none;html=1;strokeColor=#5B6770;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="975" y="118" as="sourcePoint" /><mxPoint x="975" y="840" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll5" style="endArrow=none;html=1;strokeColor=#C0392B;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1185" y="118" as="sourcePoint" /><mxPoint x="1185" y="840" as="targetPoint" /></mxGeometry></mxCell>

        <!-- ===== Messages (numbered) ===== -->
        <!-- 1 Browser -> SP : request app -->
        <mxCell id="m1" value="1 &#160;GET protected app (SP-initiated) via intranet" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;fontSize=10;fontColor=#1A1A1A;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="150" as="sourcePoint" /><mxPoint x="405" y="150" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 2 SP -> Browser : redirect + AuthnRequest -->
        <mxCell id="m2" value="2 &#160;302 Redirect + &lt;b&gt;SAML AuthnRequest&lt;/b&gt;" style="html=1;endArrow=open;dashed=1;strokeColor=#1F6FBF;strokeWidth=1.5;fontSize=10;fontColor=#1F6FBF;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="405" y="190" as="sourcePoint" /><mxPoint x="135" y="190" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 3 Browser -> IdP : AuthnRequest -->
        <mxCell id="m3" value="3 &#160;Forward &lt;b&gt;SAML AuthnRequest&lt;/b&gt; to IdP" style="html=1;endArrow=block;strokeColor=#1F6FBF;strokeWidth=1.5;fontSize=10;fontColor=#1F6FBF;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="230" as="sourcePoint" /><mxPoint x="695" y="230" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 4 IdP -> AD : validate -->
        <mxCell id="m4" value="4 &#160;Validate credentials (LDAP / Kerberos)" style="html=1;endArrow=block;strokeColor=#5A5A5A;strokeWidth=1.5;fontSize=10;fontColor=#5A5A5A;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="695" y="270" as="sourcePoint" /><mxPoint x="975" y="270" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 5 AD -> IdP : confirmed -->
        <mxCell id="m5" value="5 &#160;Identity confirmed" style="html=1;endArrow=open;dashed=1;strokeColor=#5A5A5A;strokeWidth=1.5;fontSize=10;fontColor=#5A5A5A;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="975" y="310" as="sourcePoint" /><mxPoint x="695" y="310" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 6 IdP -> MFA : request OTP -->
        <mxCell id="m6" value="6 &#160;Trigger 2nd factor &#8594; send SMS OTP" style="html=1;endArrow=block;strokeColor=#C0392B;strokeWidth=1.5;fontSize=10;fontColor=#C0392B;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="695" y="350" as="sourcePoint" /><mxPoint x="1185" y="350" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 7 MFA -> Browser : OTP to device + user submits -->
        <mxCell id="m7" value="7 &#160;OTP to device &#8594; user enters code (verified)" style="html=1;endArrow=block;startArrow=open;strokeColor=#C0392B;strokeWidth=1.5;fontSize=10;fontColor=#C0392B;align=center;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1185" y="390" as="sourcePoint" /><mxPoint x="135" y="390" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 8 IdP -> Browser : signed assertion -->
        <mxCell id="m8" value="8 &#160;302 POST &lt;b&gt;signed SAML Assertion&lt;/b&gt; &#8594; ACS" style="html=1;endArrow=open;dashed=1;strokeColor=#1F6FBF;strokeWidth=2;fontSize=10;fontColor=#1F6FBF;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="695" y="430" as="sourcePoint" /><mxPoint x="135" y="430" as="targetPoint" /></mxGeometry></mxCell>
        <!-- 9 Browser -> SP : POST assertion -->
        <mxCell id="m9" value="9 &#160;POST &lt;b&gt;SAML Assertion&lt;/b&gt; (signed / encrypted) to ACS" style="html=1;endArrow=block;strokeColor=#1F6FBF;strokeWidth=2;fontSize=10;fontColor=#1F6FBF;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="470" as="sourcePoint" /><mxPoint x="405" y="470" as="targetPoint" /></mxGeometry></mxCell>

        <!-- SP-side processing note (steps 10-13) -->
        <mxCell id="note" value="&lt;b&gt;Salesforce SP processing&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;10 &#160;Validate signature, Issuer, Audience,&lt;br/&gt;&#160;&#160;&#160;&#160;&#160;&#160;Conditions, NotOnOrAfter&lt;br/&gt;11 &#160;&lt;b&gt;JIT&lt;/b&gt; provision / update user from&lt;br/&gt;&#160;&#160;&#160;&#160;&#160;&#160;assertion attributes (first login)&lt;br/&gt;12 &#160;Apply &lt;b&gt;High-Assurance session&lt;/b&gt; +&lt;br/&gt;&#160;&#160;&#160;&#160;&#160;&#160;Login-IP (intranet) range check&lt;br/&gt;13 &#160;First login only: &lt;b&gt;ToS Login Flow&lt;/b&gt;&lt;br/&gt;&#160;&#160;&#160;&#160;&#160;&#160;&#8594; capture explicit consent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#E0B000;align=left;verticalAlign=top;fontSize=10;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="300" y="500" width="320" height="190" as="geometry" /></mxCell>

        <!-- 14 SP -> Browser : session established -->
        <mxCell id="m14" value="14 &#160;Session established &#8594; redirect to app (access granted)" style="html=1;endArrow=open;dashed=1;strokeColor=#2E8B57;strokeWidth=2;fontSize=10;fontColor=#2E8B57;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="405" y="720" as="sourcePoint" /><mxPoint x="135" y="720" as="targetPoint" /></mxGeometry></mxCell>

        <!-- ===== Legend ===== -->
        <mxCell id="lgBox" value="" style="rounded=1;arcSize=4;html=1;fillColor=#FAFAFA;strokeColor=#CCCCCC;dashed=1;" vertex="1" parent="1"><mxGeometry x="690" y="710" width="570" height="120" as="geometry" /></mxCell>
        <mxCell id="lgT" value="&lt;b&gt;LEGEND&lt;/b&gt;" style="text;html=1;align=left;fontSize=11;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="702" y="716" width="200" height="18" as="geometry" /></mxCell>
        <mxCell id="lgA" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="710" y="748" as="sourcePoint" /><mxPoint x="760" y="748" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lgAt" value="Request (front-channel via browser)" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1"><mxGeometry x="766" y="738" width="280" height="20" as="geometry" /></mxCell>
        <mxCell id="lgB" style="html=1;endArrow=open;dashed=1;strokeColor=#1F6FBF;strokeWidth=1.5;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="710" y="776" as="sourcePoint" /><mxPoint x="760" y="776" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lgBt" value="Response / 302 redirect (assertion, tokens)" style="text;html=1;align=left;fontSize=10;fontColor=#1F6FBF;" vertex="1" parent="1"><mxGeometry x="766" y="766" width="300" height="20" as="geometry" /></mxCell>
        <mxCell id="lgC" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#E0B000;" vertex="1" parent="1"><mxGeometry x="710" y="798" width="50" height="18" as="geometry" /></mxCell>
        <mxCell id="lgCt" value="Server-side processing (no browser hop)" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1"><mxGeometry x="766" y="797" width="320" height="20" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
