<mxfile host="app.diagrams.net" type="device" version="24.0.0">
  <diagram id="bedrock-iam-jwt-flow" name="OAuth JWT Bearer (S2S)">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1240" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;Server-to-Server Authorization &#8212; OAuth 2.0 JWT Bearer Flow&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="30" y="10" width="1000" height="24" as="geometry" /></mxCell>
        <mxCell id="subtitle" value="Covers R16 (server-to-server) &#183; R7 (credit bureau call) &#183; R11 (signed-token validation). NO user, NO browser, NO interactive consent &#8212; trust is established by a signed JWT." style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#5B6770;" vertex="1" parent="1"><mxGeometry x="30" y="34" width="1180" height="20" as="geometry" /></mxCell>

        <!-- Lifeline headers -->
        <mxCell id="a1" value="Backend Service&lt;br/&gt;(integration client)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F2F4F7;strokeColor=#5B6770;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="70" width="180" height="48" as="geometry" /></mxCell>
        <mxCell id="a2" value="Salesforce&lt;br/&gt;Token Endpoint (MyDomain)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8EEFB;strokeColor=#1A1A66;strokeWidth=1.5;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="520" y="70" width="200" height="48" as="geometry" /></mxCell>
        <mxCell id="a3" value="Salesforce&lt;br/&gt;API / Resource" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8EEFB;strokeColor=#1A1A66;strokeWidth=1.5;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="980" y="70" width="170" height="48" as="geometry" /></mxCell>

        <!-- Lifelines -->
        <mxCell id="ll1" style="endArrow=none;html=1;strokeColor=#5B6770;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="170" y="118" as="sourcePoint" /><mxPoint x="170" y="590" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll2" style="endArrow=none;html=1;strokeColor=#1A1A66;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="118" as="sourcePoint" /><mxPoint x="620" y="590" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll3" style="endArrow=none;html=1;strokeColor=#1A1A66;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1065" y="118" as="sourcePoint" /><mxPoint x="1065" y="590" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Build/sign note -->
        <mxCell id="buildNote" value="&lt;b&gt;1 &#160;Build + sign JWT&lt;/b&gt;&lt;br/&gt;Claims: iss=client_id, sub=user,&lt;br/&gt;aud=login URL, exp&lt;br/&gt;Signed with private key&lt;br/&gt;(cert pre-registered on Connected App)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#E0B000;align=left;verticalAlign=top;fontSize=10;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="60" y="135" width="230" height="100" as="geometry" /></mxCell>

        <!-- Named credential note -->
        <mxCell id="ncNote" value="&lt;b&gt;Named Credential&lt;/b&gt; stores the signing cert + token endpoint &#8212; no secrets in code." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF4FF;strokeColor=#3B6FD4;align=left;verticalAlign=middle;fontSize=10;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="60" y="250" width="230" height="50" as="geometry" /></mxCell>

        <!-- Messages -->
        <mxCell id="m2" value="2 &#160;POST /token: grant_type=jwt-bearer, assertion=&lt;b&gt;&amp;lt;signed JWT&amp;gt;&lt;/b&gt;" style="html=1;endArrow=block;strokeColor=#E8762C;strokeWidth=2;fontSize=10;fontColor=#E8762C;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="170" y="330" as="sourcePoint" /><mxPoint x="620" y="330" as="targetPoint" /></mxGeometry></mxCell>

        <mxCell id="vNote" value="3 &#160;Validate JWT &lt;b&gt;signature&lt;/b&gt; against registered cert;&lt;br/&gt;&#160;&#160;&#160;&#160;&#160;check iss / sub / aud / exp; confirm admin pre-authorized the client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#E0B000;align=left;verticalAlign=middle;fontSize=10;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="430" y="355" width="500" height="56" as="geometry" /></mxCell>

        <mxCell id="m4" value="4 &#160;&lt;b&gt;access_token&lt;/b&gt; &#160;(no refresh token in JWT-bearer)" style="html=1;endArrow=open;dashed=1;strokeColor=#E8762C;strokeWidth=2;fontSize=10;fontColor=#E8762C;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="455" as="sourcePoint" /><mxPoint x="170" y="455" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m5" value="5 &#160;GET /resource (Authorization: Bearer access_token)" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;fontSize=10;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="170" y="495" as="sourcePoint" /><mxPoint x="1065" y="495" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m6" value="6 &#160;Protected data response" style="html=1;endArrow=open;dashed=1;strokeColor=#2E8B57;strokeWidth=2;fontSize=10;fontColor=#2E8B57;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1065" y="535" as="sourcePoint" /><mxPoint x="170" y="535" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Callout -->
        <mxCell id="callout" value="&lt;b&gt;Why JWT Bearer (vs Auth-Code+PKCE)?&lt;/b&gt;&#160;&#160;No human is present. The signed JWT IS the proof of the client&#39;s identity, so there is no browser redirect and no consent screen. Use for backend jobs &amp;amp; the real-time credit-bureau call." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FB;strokeColor=#9AA3B2;align=left;verticalAlign=middle;fontSize=10;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="300" y="250" width="640" height="56" as="geometry" /></mxCell>

        <!-- Legend -->
        <mxCell id="lgBox" value="" style="rounded=1;arcSize=4;html=1;fillColor=#FAFAFA;strokeColor=#CCCCCC;dashed=1;" vertex="1" parent="1"><mxGeometry x="300" y="560" width="640" height="58" as="geometry" /></mxCell>
        <mxCell id="lgA" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="315" y="592" as="sourcePoint" /><mxPoint x="365" y="592" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lgAt" value="Request" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1"><mxGeometry x="371" y="582" width="90" height="20" as="geometry" /></mxCell>
        <mxCell id="lgB" style="html=1;endArrow=open;dashed=1;strokeColor=#E8762C;strokeWidth=2;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="470" y="592" as="sourcePoint" /><mxPoint x="520" y="592" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lgBt" value="Token response" style="text;html=1;align=left;fontSize=10;fontColor=#E8762C;" vertex="1" parent="1"><mxGeometry x="526" y="582" width="130" height="20" as="geometry" /></mxCell>
        <mxCell id="lgC" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#E0B000;" vertex="1" parent="1"><mxGeometry x="660" y="584" width="40" height="16" as="geometry" /></mxCell>
        <mxCell id="lgCt" value="Server-side / sign step" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1"><mxGeometry x="706" y="582" width="200" height="20" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
