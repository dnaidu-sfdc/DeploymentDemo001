        <mxCell id="title" value="&lt;b&gt;Complex External-Party Flows &#8212; Partner multi-IdP (Login Discovery) &amp;amp; PayPal (authN + payment authZ)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="30" y="10" width="1200" height="24" as="geometry" /></mxCell>

