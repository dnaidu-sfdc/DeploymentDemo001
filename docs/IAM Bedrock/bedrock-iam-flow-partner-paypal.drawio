        <mxCell id="panelAt" value="&lt;b&gt;A &#183; PARTNER FEDERATION &#8212; each partner org uses its OWN enterprise IdP (R13)&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontColor=#5B3FA0;" vertex="1" parent="1"><mxGeometry x="32" y="56" width="900" height="20" as="geometry" /></mxCell>

