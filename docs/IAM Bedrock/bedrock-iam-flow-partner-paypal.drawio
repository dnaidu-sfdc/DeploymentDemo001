        <mxCell id="pall2" style="endArrow=none;html=1;strokeColor=#1A1A66;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="420" y="132" as="sourcePoint" /><mxPoint x="420" y="470" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="pall3" style="endArrow=none;html=1;strokeColor=#7A4FD0;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="720" y="132" as="sourcePoint" /><mxPoint x="720" y="470" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="pall4" style="endArrow=none;html=1;strokeColor=#B5651D;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1020" y="132" as="sourcePoint" /><mxPoint x="1020" y="470" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Panel A messages -->
        <mxCell id="pm1" value="1 &#160;Enter email / identifier (no password field)" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;fontSize=10;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="170" as="sourcePoint" /><mxPoint x="420" y="170" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="pm2" value="2 &#160;Resolve identifier &#8594; which partner org?" style="html=1;endArrow=block;strokeColor=#7A4FD0;strokeWidth=1.5;fontSize=10;fontColor=#7A4FD0;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="420" y="208" as="sourcePoint" /><mxPoint x="720" y="208" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="pm3" value="3 &#160;Route to that partner&#39;s SAML IdP" style="html=1;endArrow=open;dashed=1;strokeColor=#7A4FD0;strokeWidth=1.5;fontSize=10;fontColor=#7A4FD0;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="720" y="246" as="sourcePoint" /><mxPoint x="420" y="246" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="pm4" value="4 &#160;302 redirect + &lt;b&gt;SAML AuthnRequest&lt;/b&gt;" style="html=1;endArrow=open;dashed=1;strokeColor=#1F6FBF;strokeWidth=1.5;fontSize=10;fontColor=#1F6FBF;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="420" y="284" as="sourcePoint" /><mxPoint x="135" y="284" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="pm5" value="5 &#160;Forward AuthnRequest to partner IdP" style="html=1;endArrow=block;strokeColor=#1F6FBF;strokeWidth=1.5;fontSize=10;fontColor=#1F6FBF;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="322" as="sourcePoint" /><mxPoint x="1020" y="322" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="pm6" value="6 &#160;Authenticate (partner&#39;s own creds / MFA) &#8594; &lt;b&gt;signed SAML Assertion&lt;/b&gt;" style="html=1;endArrow=open;dashed=1;strokeColor=#1F6FBF;strokeWidth=2;fontSize=10;fontColor=#1F6FBF;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1020" y="360" as="sourcePoint" /><mxPoint x="135" y="360" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="pm7" value="7 &#160;POST &lt;b&gt;signed SAML Assertion&lt;/b&gt; &#8594; ACS" style="html=1;endArrow=block;strokeColor=#1F6FBF;strokeWidth=2;fontSize=10;fontColor=#1F6FBF;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="398" as="sourcePoint" /><mxPoint x="420" y="398" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="paNote" value="8 &#160;Validate assertion &#8594; JIT provision/update &#8594; Experience Cloud session.&#160;&#160;One site, MANY SAML trusts, zero shared credentials." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#E0B000;align=left;verticalAlign=middle;fontSize=10;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="150" y="418" width="700" height="44" as="geometry" /></mxCell>

