        <mxCell id="pb3" value="PayPal&lt;br/&gt;(OIDC / OAuth)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FBEFE0;strokeColor=#E8762C;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="780" y="536" width="170" height="46" as="geometry" /></mxCell>

        <!-- Panel B lifelines -->
        <mxCell id="pbll1" style="endArrow=none;html=1;strokeColor=#2E8B57;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="582" as="sourcePoint" /><mxPoint x="135" y="900" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="pbll2" style="endArrow=none;html=1;strokeColor=#1A1A66;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="490" y="582" as="sourcePoint" /><mxPoint x="490" y="900" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="pbll3" style="endArrow=none;html=1;strokeColor=#E8762C;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="865" y="582" as="sourcePoint" /><mxPoint x="865" y="900" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Panel B messages -->
        <mxCell id="qm1" value="1 &#160;Checkout &#8594; &#39;Pay with PayPal&#39;" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;fontSize=10;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="620" as="sourcePoint" /><mxPoint x="490" y="620" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="qm2" value="2 &#160;302 redirect &#8594; PayPal authorize (OIDC scopes + payment authZ)" style="html=1;endArrow=open;dashed=1;strokeColor=#E8762C;strokeWidth=1.5;fontSize=10;fontColor=#E8762C;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="490" y="658" as="sourcePoint" /><mxPoint x="135" y="658" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="qm3" value="3 &#160;Authenticate + authorize payment (one session)" style="html=1;endArrow=block;strokeColor=#E8762C;strokeWidth=1.5;fontSize=10;fontColor=#E8762C;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="696" as="sourcePoint" /><mxPoint x="865" y="696" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="qm4" value="4 &#160;302 redirect &#8594; callback?&lt;b&gt;code&lt;/b&gt;=&#8230;" style="html=1;endArrow=open;dashed=1;strokeColor=#E8762C;strokeWidth=1.5;fontSize=10;fontColor=#E8762C;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="865" y="734" as="sourcePoint" /><mxPoint x="135" y="734" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="qm5" value="5 &#160;Deliver authorization code" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;fontSize=10;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="772" as="sourcePoint" /><mxPoint x="490" y="772" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="qm6" value="6 &#160;Exchange code &#8594; tokens (back-channel, server-to-server)" style="html=1;endArrow=block;strokeColor=#E8762C;strokeWidth=2;fontSize=10;fontColor=#E8762C;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="490" y="810" as="sourcePoint" /><mxPoint x="865" y="810" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="qm7" value="7 &#160;&lt;b&gt;id_token&lt;/b&gt; (identity) + access (payment authZ)" style="html=1;endArrow=open;dashed=1;strokeColor=#E8762C;strokeWidth=2;fontSize=10;fontColor=#E8762C;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="865" y="848" as="sourcePoint" /><mxPoint x="490" y="848" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="pbNote" value="8 &#160;&lt;b&gt;Registration Handler&lt;/b&gt; maps PayPal federation Id &#8594; Salesforce user (&lt;b&gt;identity mapping&lt;/b&gt;).&#160;Trusted SF session established &#8212; authentication context is kept separate from the payment context (secure handoff)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#E0B000;align=left;verticalAlign=middle;fontSize=10;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="150" y="868" width="900" height="48" as="geometry" /></mxCell>

