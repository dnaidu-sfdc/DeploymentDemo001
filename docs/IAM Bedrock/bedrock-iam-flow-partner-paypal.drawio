  <diagram id="bedrock-iam-partner-paypal" name="Partner multi-IdP + PayPal">
    <mxGraphModel dx="1200" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1280" pageHeight="1010" math="0" shadow="0">
      <root>
