        <mxCell id="panelBt" value="&lt;b&gt;B &#183; PAYPAL &#8212; authenticate + authorize payment in ONE session, then identity-map to Salesforce (R14)&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontColor=#B5651D;" vertex="1" parent="1"><mxGeometry x="32" y="506" width="1000" height="20" as="geometry" /></mxCell>

