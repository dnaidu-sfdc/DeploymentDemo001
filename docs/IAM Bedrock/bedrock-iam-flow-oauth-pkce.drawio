<mxfile host="app.diagrams.net" type="device" version="24.0.0">
  <diagram id="bedrock-iam-pkce-flow" name="OAuth Auth-Code + PKCE">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;b&gt;User Authorization &#8212; OAuth 2.0 Authorization-Code + PKCE (branded mobile / public client)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="30" y="10" width="1150" height="24" as="geometry" /></mxCell>
        <mxCell id="subtitle" value="Covers R4 (branded mobile + MFA) &#183; R11 (encryption/validation). A user IS present and consents. PKCE protects the public client &#8212; no client secret on the device." style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#5B6770;" vertex="1" parent="1"><mxGeometry x="30" y="34" width="1200" height="20" as="geometry" /></mxCell>

        <!-- Lifeline headers -->
        <mxCell id="a1" value="Mobile App&lt;br/&gt;(public client)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FBEFE0;strokeColor=#E8762C;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="70" width="150" height="48" as="geometry" /></mxCell>
        <mxCell id="a2" value="System&lt;br/&gt;Browser" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DCE8FB;strokeColor=#3B6FD4;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="330" y="70" width="150" height="48" as="geometry" /></mxCell>
        <mxCell id="a3" value="Salesforce&lt;br/&gt;Authorize Endpoint (MyDomain)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8EEFB;strokeColor=#1A1A66;strokeWidth=1.5;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="610" y="70" width="190" height="48" as="geometry" /></mxCell>
        <mxCell id="a4" value="Salesforce&lt;br/&gt;Token / API Endpoint" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8EEFB;strokeColor=#1A1A66;strokeWidth=1.5;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="930" y="70" width="170" height="48" as="geometry" /></mxCell>

        <!-- Lifelines -->
        <mxCell id="ll1" style="endArrow=none;html=1;strokeColor=#E8762C;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="118" as="sourcePoint" /><mxPoint x="135" y="730" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll2" style="endArrow=none;html=1;strokeColor=#3B6FD4;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="405" y="118" as="sourcePoint" /><mxPoint x="405" y="730" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll3" style="endArrow=none;html=1;strokeColor=#1A1A66;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="705" y="118" as="sourcePoint" /><mxPoint x="705" y="730" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="ll4" style="endArrow=none;html=1;strokeColor=#1A1A66;dashed=1;dashPattern=4 4;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1015" y="118" as="sourcePoint" /><mxPoint x="1015" y="730" as="targetPoint" /></mxGeometry></mxCell>

        <!-- PKCE generation note -->
        <mxCell id="pkceNote" value="&lt;b&gt;PKCE&lt;/b&gt;: app generates&lt;br/&gt;code_verifier + code_challenge (S256)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#E0B000;align=left;fontSize=9;spacingLeft=6;" vertex="1" parent="1"><mxGeometry x="45" y="128" width="200" height="40" as="geometry" /></mxCell>

        <!-- Messages -->
        <mxCell id="m1" value="1 &#160;Launch /authorize: client_id, redirect_uri, scope, state, &lt;b&gt;code_challenge&lt;/b&gt;" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;fontSize=10;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="195" as="sourcePoint" /><mxPoint x="405" y="195" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m2" value="2 &#160;GET /authorize" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;fontSize=10;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="405" y="235" as="sourcePoint" /><mxPoint x="705" y="235" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m3" value="3 &#160;Login + &lt;b&gt;MFA (SMS OTP)&lt;/b&gt; + Consent screen" style="html=1;endArrow=open;dashed=1;strokeColor=#C0392B;strokeWidth=1.5;fontSize=10;fontColor=#C0392B;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="705" y="275" as="sourcePoint" /><mxPoint x="405" y="275" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m4" value="4 &#160;User authenticates + grants consent" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;fontSize=10;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="405" y="315" as="sourcePoint" /><mxPoint x="705" y="315" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m5" value="5 &#160;302 redirect &#8594; redirect_uri?&lt;b&gt;code&lt;/b&gt;=&#8230;&amp;state" style="html=1;endArrow=open;dashed=1;strokeColor=#E8762C;strokeWidth=2;fontSize=10;fontColor=#E8762C;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="705" y="355" as="sourcePoint" /><mxPoint x="405" y="355" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m6" value="6 &#160;Deliver authorization &lt;b&gt;code&lt;/b&gt;" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;fontSize=10;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="405" y="395" as="sourcePoint" /><mxPoint x="135" y="395" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m7" value="7 &#160;POST /token: code + &lt;b&gt;code_verifier&lt;/b&gt; + client_id + redirect_uri" style="html=1;endArrow=block;strokeColor=#E8762C;strokeWidth=2;fontSize=10;fontColor=#E8762C;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="435" as="sourcePoint" /><mxPoint x="1015" y="435" as="targetPoint" /></mxGeometry></mxCell>

        <mxCell id="vNote" value="8 &#160;Validate: SHA256(code_verifier) == code_challenge&lt;br/&gt;&#160;&#160;&#160;&#160;&#160;(proves same client that started the flow)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#E0B000;align=left;verticalAlign=middle;fontSize=10;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="780" y="460" width="470" height="56" as="geometry" /></mxCell>

        <mxCell id="m9" value="9 &#160;&lt;b&gt;access_token&lt;/b&gt; + &lt;b&gt;refresh_token&lt;/b&gt; + &lt;b&gt;id_token&lt;/b&gt;" style="html=1;endArrow=open;dashed=1;strokeColor=#E8762C;strokeWidth=2;fontSize=10;fontColor=#E8762C;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1015" y="560" as="sourcePoint" /><mxPoint x="135" y="560" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m10" value="10 &#160;GET /resource (Authorization: Bearer access_token)" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;fontSize=10;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="135" y="600" as="sourcePoint" /><mxPoint x="1015" y="600" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m11" value="11 &#160;Protected resource response" style="html=1;endArrow=open;dashed=1;strokeColor=#2E8B57;strokeWidth=2;fontSize=10;fontColor=#2E8B57;align=left;verticalAlign=bottom;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1015" y="640" as="sourcePoint" /><mxPoint x="135" y="640" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Legend -->
        <mxCell id="lgBox" value="" style="rounded=1;arcSize=4;html=1;fillColor=#FAFAFA;strokeColor=#CCCCCC;dashed=1;" vertex="1" parent="1"><mxGeometry x="45" y="660" width="700" height="64" as="geometry" /></mxCell>
        <mxCell id="lgT" value="&lt;b&gt;LEGEND&lt;/b&gt;" style="text;html=1;align=left;fontSize=11;" vertex="1" parent="1"><mxGeometry x="55" y="664" width="120" height="18" as="geometry" /></mxCell>
        <mxCell id="lgA" style="html=1;endArrow=block;strokeColor=#1A1A1A;strokeWidth=1.5;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="60" y="700" as="sourcePoint" /><mxPoint x="110" y="700" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lgAt" value="Request / front-channel" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1"><mxGeometry x="116" y="690" width="180" height="20" as="geometry" /></mxCell>
        <mxCell id="lgB" style="html=1;endArrow=open;dashed=1;strokeColor=#E8762C;strokeWidth=2;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="310" y="700" as="sourcePoint" /><mxPoint x="360" y="700" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lgBt" value="Response (code / tokens)" style="text;html=1;align=left;fontSize=10;fontColor=#E8762C;" vertex="1" parent="1"><mxGeometry x="366" y="690" width="190" height="20" as="geometry" /></mxCell>
        <mxCell id="lgC" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#E0B000;" vertex="1" parent="1"><mxGeometry x="566" y="692" width="40" height="16" as="geometry" /></mxCell>
        <mxCell id="lgCt" value="Server-side step" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1"><mxGeometry x="612" y="690" width="130" height="20" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
