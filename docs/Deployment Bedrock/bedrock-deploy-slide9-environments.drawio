        <!-- ===== INFO PANEL: REFRESH CHECKLIST ===== -->
        <mxCell id="refBox" value="" style="rounded=0;html=1;fillColor=#F2F4F7;strokeColor=#5B6770;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="20" y="396" width="650" height="180" as="geometry" /></mxCell>
        <mxCell id="refTitle" value="&lt;b&gt;SANDBOX REFRESH CHECKLIST (post-refresh automation)&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#3B3B3B;" vertex="1" parent="1"><mxGeometry x="32" y="404" width="620" height="18" as="geometry" /></mxCell>
        <mxCell id="refList" value="&#8226; Mask / seed PII &#8212; regulated (Healthcare + Financial) data&lt;br/&gt;&#8226; Deactivate outbound integrations &amp; email deliverability&lt;br/&gt;&#8226; Re-point Named Credentials / endpoints to sandbox&lt;br/&gt;&#8226; Reassign permission sets &amp; sample users&lt;br/&gt;&#8226; Re-connect CI/CD service accounts &amp; auth&lt;br/&gt;&#8226; Load managed test data set&lt;br/&gt;&#8226; Re-apply sandbox-specific config &amp; feature flags" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="32" y="426" width="620" height="140" as="geometry" /></mxCell>

        <!-- ===== INFO PANEL: DATA 360 ===== -->
        <mxCell id="dcBox" value="" style="rounded=0;html=1;fillColor=#E1F5FE;strokeColor=#0277BD;strokeWidth=1;" vertex="1" parent="1"><mxGeometry x="690" y="396" width="650" height="180" as="geometry" /></mxCell>
        <mxCell id="dcTitle" value="&lt;b&gt;DATA 360 (DATA CLOUD) SANDBOX STRATEGY&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#01579B;" vertex="1" parent="1"><mxGeometry x="702" y="404" width="620" height="18" as="geometry" /></mxCell>
        <mxCell id="dcList" value="&#8226; Data Cloud is NOT auto-copied on sandbox refresh&lt;br/&gt;&#8226; Provision Data Cloud in the sandbox explicitly&lt;br/&gt;&#8226; Redeploy data streams / DLOs / DMOs / mappings / segments&lt;br/&gt;&#8226; Re-point ingestion to masked / subset sources&lt;br/&gt;&#8226; Validate identity resolution before promotion&lt;br/&gt;&#8226; Control ingestion cost by using representative subsets&lt;br/&gt;&#8226; Scratch orgs carry the shape so DC + Agentforce metadata validate in CI" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#1A1A1A;" vertex="1" parent="1"><mxGeometry x="702" y="426" width="628" height="140" as="geometry" /></mxCell>

