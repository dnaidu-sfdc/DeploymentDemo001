        <mxCell id="title" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=15;fontColor=#1A1A1A;" value="&lt;b&gt;Bedrock — CI/CD Pipeline Flow (DevSecOps)&lt;/b&gt;" vertex="1">
          <mxGeometry height="24" width="1100" x="20" y="8" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#5B6770;" value="Git-native pipeline (sf CLI + CI runner) · validate-early · security gated (shift-left) · pipeline-only deploy to Production" vertex="1">
          <mxGeometry height="20" width="1250" x="20" y="32" as="geometry" />
        </mxCell>
        <mxCell id="secBanner" parent="1" style="rounded=0;html=1;align=left;verticalAlign=middle;fillColor=#FDF6F6;strokeColor=#F0C9C9;fontSize=10;fontColor=#5B6770;" value="&lt;b&gt;Cross-cutting security:&lt;/b&gt;  secrets in vault (Key Vault / Actions secrets) · JWT-bearer auth · CI service accounts (least privilege) · &lt;font color=&#39;#C0392B&#39;&gt;red = security gate&lt;/font&gt;" vertex="1">
          <mxGeometry height="28" width="1340" x="20" y="58" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#EEF3FC;strokeColor=#3B6FD4;fontSize=10;spacing=6;" value="&lt;b&gt;1 · SOURCE / TRIGGER&lt;/b&gt;&lt;br/&gt;&lt;br/&gt;• Developer commit&lt;br/&gt;• Open PR&lt;br/&gt;  (feature → integration)&lt;br/&gt;• SFDX source format" vertex="1">
          <mxGeometry height="210" width="240" x="20" y="100" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=10;spacing=6;" value="&lt;b&gt;2 · CI VALIDATE (on PR)&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#C0392B&quot;&gt;• Static analysis PMD, ESLINT, SONAR — Code Analyzer (SAST/SCA)&lt;/font&gt;&lt;br&gt;• Apex + LWC unit tests&lt;br&gt;&lt;font color=&quot;#C0392B&quot;&gt;• Secret scan&lt;/font&gt;&lt;br&gt;• Validate-only deploy&lt;br&gt;&amp;nbsp;&amp;nbsp;(CI scratch org)&lt;br&gt;• ✅ Required checks → merge gate" vertex="1">
          <mxGeometry height="210" width="240" x="300" y="100" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;spacing=6;" value="&lt;b&gt;3 · INTEGRATION / UAT&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:9px&#39;&gt;(on merge to integration)&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;• Auto-deploy&lt;br/&gt;• Integration + functional tests&lt;br/&gt;• UAT sign-off" vertex="1">
          <mxGeometry height="210" width="240" x="580" y="100" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#FFF8E1;strokeColor=#F9A825;fontSize=10;spacing=6;" value="&lt;b&gt;4 · STAGING&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;(on release branch)&lt;/font&gt;&lt;br&gt;&lt;br&gt;• Deploy&lt;br&gt;• Regression + performance&lt;br&gt;&lt;font color=&quot;#C0392B&quot;&gt;• DAST scan (Checkmarx)&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="240" x="860" y="100" as="geometry" />
