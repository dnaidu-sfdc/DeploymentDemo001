  <diagram id="bedrock-deploy-cicd" name="Slide 10 - CICD Pipeline Flow">
    <mxGraphModel dx="1522" dy="700" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1380" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
