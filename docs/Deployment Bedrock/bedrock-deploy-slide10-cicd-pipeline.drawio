        <mxCell id="s5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#E8EEFB;strokeColor=#1A1A66;strokeWidth=2;fontSize=10;fontColor=#1A1A66;spacing=6;" value="&lt;b&gt;5 · PRODUCTION&lt;/b&gt;&lt;br/&gt;&lt;font style=&#39;font-size:9px&#39;&gt;(on tag / main)&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;• Manual approval gate&lt;br/&gt;• Pipeline-only deploy&lt;br/&gt;&lt;font color=&#39;#C0392B&#39;&gt;• Attach evidence&lt;br/&gt;  (tests + scans)&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="240" x="1120" y="100" as="geometry" />
