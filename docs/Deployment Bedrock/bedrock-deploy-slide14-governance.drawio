        <mxCell id="subtitle" value="Program &#183; Architecture/Technical &#183; Data governance &#183; decision rights that keep a multi-SI program aligned" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#5B6770;" vertex="1" parent="1"><mxGeometry x="20" y="32" width="1250" height="20" as="geometry" /></mxCell>

